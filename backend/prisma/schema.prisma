generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////////////////////////////////////
// USER
///////////////////////////////////////////////////////

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String?
  googleId String? @unique

  plan String @default("basic")

  emailVerified        Boolean   @default(false)
  verificationToken    String?   @unique
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  transactions Transaction[]
  categories   Category[]
  audits       AuditLog[]

  // ✅ FIXED RELATIONS
  subscriptions Subscription[]
  invoices      Invoice[]
  usage         Usage[]

  @@index([deletedAt])
  @@index([email])
}

///////////////////////////////////////////////////////
// CATEGORY
///////////////////////////////////////////////////////

model Category {
  id      String  @id @default(cuid())
  name    String
  parent  String?
  icon    String?
  builtIn Boolean @default(false)

  isRevenue Boolean @default(false)
  isCOGS    Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
  @@index([deletedAt])
}

///////////////////////////////////////////////////////
// TRANSACTION
///////////////////////////////////////////////////////

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  description String
  amount      Float
  categoryId  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([categoryId])
  @@index([date])
}

///////////////////////////////////////////////////////
// AUDIT LOG
///////////////////////////////////////////////////////

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
}

///////////////////////////////////////////////////////
// SUBSCRIPTION
///////////////////////////////////////////////////////

model Subscription {
  id               String    @id @default(uuid())
  userId           String
  paddleCustomer   String?
  paddleSubId      String?
  plan             String
  status           String
  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

///////////////////////////////////////////////////////
// INVOICE
///////////////////////////////////////////////////////

model Invoice {
  id       String @id @default(uuid())
  userId   String
  amount   Float
  currency String
  status   String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

///////////////////////////////////////////////////////
// USAGE
///////////////////////////////////////////////////////

model Usage {
  id     String @id @default(uuid())
  userId String
  type   String
  count  Int

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
